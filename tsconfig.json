{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020"],
    "module": "ESNext",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@technovan/types": ["shared/types/src"],
      "@technovan/utils": ["shared/utils/src"],
      "@technovan/ui": ["shared/ui/src"]
    }
  },
  "include": ["apps", "backend", "shared"],
  "exclude": ["node_modules", "dist", "build"]
}
