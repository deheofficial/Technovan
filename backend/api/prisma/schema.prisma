// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  CUSTOMER
  SUPPORT
}

enum ProjectStatus {
  PENDING
  APPROVED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

model User {
  id            String     @id @default(cuid())
  email         String     @unique
  password      String
  firstName     String
  lastName      String
  phone         String?
  company       String?
  role          UserRole   @default(CUSTOMER)
  avatar        String?
  isActive      Boolean    @default(true)
  emailVerified Boolean    @default(false)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  projects      Project[]
  inquiries     Inquiry[]
  payments      Payment[]
  messages      Message[]

  @@index([email])
  @@index([role])
}

model Service {
  id          String   @id @default(cuid())
  title       String
  description String
  icon        String?
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive])
}

model Pricing {
  id          String   @id @default(cuid())
  name        String   @unique
  price       Float
  currency    String   @default("RM")
  description String?
  features    String[]
  isActive    Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  projects Project[]

  @@index([isActive])
}

model Project {
  id          String        @id @default(cuid())
  title       String
  description String
  status      ProjectStatus @default(PENDING)
  pricingId   String
  pricing     Pricing       @relation(fields: [pricingId], references: [id])
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  budget      Float?
  deadline    DateTime?
  files       String[]
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  messages Message[]
  payments Payment[]

  @@index([userId])
  @@index([status])
  @@index([pricingId])
}

model Inquiry {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  message   String
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  isRead    Boolean  @default(false)
  responded Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([isRead])
}

model Message {
  id        String   @id @default(cuid())
  content   String
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([projectId])
  @@index([userId])
}

model Payment {
  id              String        @id @default(cuid())
  amount          Float
  currency        String        @default("RM")
  status          PaymentStatus @default(PENDING)
  method          String        // stripe, paypal, bank_transfer
  transactionId   String?       @unique
  projectId       String
  project         Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId          String
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  invoiceUrl      String?
  description     String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([userId])
  @@index([projectId])
  @@index([status])
}

model Portfolio {
  id          String   @id @default(cuid())
  title       String
  description String
  image       String?
  link        String?
  category    String
  isActive    Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive])
  @@index([category])
}

model BlogPost {
  id        String   @id @default(cuid())
  title     String
  content   String
  excerpt   String?
  image     String?
  slug      String   @unique
  published Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([published])
  @@index([slug])
}

model Analytics {
  id           String   @id @default(cuid())
  pageView     Int      @default(0)
  uniqueUsers  Int      @default(0)
  totalRevenue Float    @default(0)
  date         DateTime @default(now())
  createdAt    DateTime @default(now())

  @@index([date])
}
